NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/attendance_system
JWT_SECRET=replace_with_a_long_random_secret
QR_SIGNING_SECRET=replace_with_a_different_long_random_secret
FRONTEND_URL=https://your-frontend.onrender.com
ATTENDANCE_RADIUS_METERS=100
ATTENDANCE_MAX_ACCURACY_METERS=150
ALLOW_INSECURE_DEV_ATTENDANCE=false

# Optional email settings for low-attendance alerts
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
